; TxtGame 项目 npm 镜像配置
; 锁定阿里云镜像（npmmirror.com），避免 npmjs.org 在国内的网络抖动
; 配合 docs/environment-setup.md 的 playwright 浏览器下载代理使用

registry=https://registry.npmmirror.com

; 引擎二进制镜像（node-sass / node-pre-gyp 等原生模块用得到）
disturl=https://npmmirror.com/dist
electron_mirror=https://npmmirror.com/mirrors/electron/
sass_binary_site=https://npmmirror.com/mirrors/node-sass
sharp_binary_host=https://npmmirror.com/mirrors/sharp
sharp_libvips_binary_host=https://npmmirror.com/mirrors/sharp-libvips

; Playwright 浏览器下载代理（仍需在 shell 临时设置环境变量，
; 因为 .npmrc 不支持 PLAYWRIGHT_*_HOST 之类变量）
; 见 docs/environment-setup.md
